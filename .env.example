# ============================================================================
# arolariu.ro Monorepo — Environment Variables Reference
# ============================================================================
#
# This file documents all environment variables used across the monorepo.
# Copy to `.env` and fill in values for local bare-metal development.
#
# For Docker Compose development, see infra/Local/readme.md instead.
# For production, config is resolved via the exp service (not .env files).
#
# TIP: Run `npm run generate:env` to auto-generate .env with defaults.
# ============================================================================

# ── Website (sites/arolariu.ro) ──────────────────────────────────────────────

# Site identity
SITE_ENV=DEVELOPMENT                         # "DEVELOPMENT" or "PRODUCTION"
SITE_NAME=dev.arolariu.ro                    # Site display name
SITE_URL=http://localhost:3000               # Public URL of the website

# Authentication (Clerk) — get keys from https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=           # Clerk publishable key (pk_test_...)
CLERK_SECRET_KEY=                            # Clerk secret key (sk_test_...)

# Azure identity (optional — only needed for Azure resource access)
AZURE_CLIENT_ID=                             # Managed identity client ID
AZURE_TENANT_ID=                             # Azure AD tenant ID
AZURE_SUBSCRIPTION_ID=                       # Azure subscription ID

# Build metadata (auto-populated by CI/CD)
TIMESTAMP=                                   # Build timestamp (ISO 8601)
COMMIT_SHA=                                  # Git commit SHA
USE_CDN=false                                # "true" to use CDN asset prefix

# ── API (sites/api.arolariu.ro) ──────────────────────────────────────────────

# Runtime
ASPNETCORE_ENVIRONMENT=Development           # "Development" or "Production"
API_NAME=arolariu-backend-api                # API display name
API_URL=http://localhost:5000                # Public URL of the API
EXP_PROXY_URL=http://localhost:5002          # Override exp service URL for bare-metal dev (default: http://exp for Docker)

# ── exp Service (sites/exp.arolariu.ro) ──────────────────────────────────────

# Runtime
INFRA=local                                  # "local" or "azure"
EXP_CONFIG_REFRESH_INTERVAL_SECONDS=300      # Config cache TTL in seconds
EXP_LOCAL_CONFIG_PATH=                       # Path to config.docker.json (Docker only)

# ── Shared / Cross-Service ───────────────────────────────────────────────────

# API authentication secret (shared between website and API)
API_JWT=                                     # JWT signing key (base64)

# Email (optional)
RESEND_API_KEY=                              # Resend.com API key for transactional email

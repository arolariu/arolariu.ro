# Only allow exact version matches when installing dependencies.
# This is useful to avoid issues with semver ranges.
save-exact=true

# Force the public npm registry to prevent private/corporate registry
# URLs from leaking into package-lock.json (causes E401 in CI).
registry=https://registry.npmjs.org/

# The text for the npm cli.
# This is displayed as the heading for the npm commands.
heading='@arolariu/npm'

# Enforce Node.js version from package.json engines field.
engine-strict=true

# Reduce npm output noise.
fund=false
audit-level=moderate

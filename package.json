{
  "license": "MIT",
  "name": "@arolariu/monorepo",
  "type": "module",
  "version": "0.0.0",
  "description": "Monorepo for all arolariu.ro projects and packages",
  "private": true,
  "author": {
    "email": "admin@arolariu.ro",
    "name": "Alexandru-Razvan Olariu",
    "url": "https://arolariu.ro"
  },
  "workspaces": [
    "packages/*",
    "sites/*"
  ],
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arolariu/arolariu.ro"
  },
  "scripts": {
    "__runner__based__commands__start__": "⚠️ The below section contains commands based on NX runner.",
    "build": "nx run-many --target=build --all",
    "build:api": "nx run api:build",
    "build:components": "nx run components:build",
    "build:cv": "nx run cv:build",
    "build:docs": "nx run docs:build",
    "build:website": "nx run website:build",
    "docs:typedoc": "npm run docs:typedoc:components && npm run docs:typedoc:website",
    "docs:typedoc:components": "npx typedoc --options typedoc.components.json",
    "docs:typedoc:website": "npx typedoc --options typedoc.website.json",
    "dev": "nx run-many --target=dev --all --parallel",
    "dev:api": "nx run api:dev",
    "dev:components": "nx run components:dev",
    "dev:cv": "nx run cv:dev",
    "dev:docs": "nx run docs:dev",
    "dev:website": "nx run website:dev",
    "nx": "nx",
    "graph": "nx graph",
    "test": "nx run-many --target=test --all",
    "test:unit": "nx run-many --target=test --configuration=unit --all",
    "test:api": "nx run api:test",
    "test:components": "nx run components:test",
    "test:cv": "nx run cv:test",
    "test:website": "nx run website:test",
    "__runner__based__commands__finish__": "✅ The above section contains commands based on NX runner.",
    "___________________________________": "",
    "__script__based__commands__start__": "⚠️ The below section contains commands based on node runner.",
    "setup": "node scripts/setup.ts",
    "doctor": "node scripts/doctor.ts",
    "format": "node scripts/format.ts all",
    "format:components": "node scripts/format.ts packages",
    "format:cv": "node scripts/format.ts cv",
    "format:website": "node scripts/format.ts website",
    "format:api": "node scripts/format.ts api",
    "lint": "node scripts/lint.ts all",
    "lint:components": "node scripts/lint.ts packages",
    "lint:cv": "node scripts/lint.ts cv",
    "lint:website": "node scripts/lint.ts website",
    "lint:inspect:eslint": "eslint --inspect-config",
    "test:e2e": "node scripts/test-e2e.ts all",
    "test:e2e:backend": "node scripts/test-e2e.ts backend",
    "test:e2e:cv": "node scripts/test-e2e.ts cv",
    "test:e2e:frontend": "node scripts/test-e2e.ts frontend",
    "generate": "node scripts/generate.ts",
    "generate:acks": "node scripts/generate.acks.ts",
    "generate:env": "node scripts/generate.env.ts",
    "generate:gql": "node scripts/generate.gql.ts",
    "generate:i18n": "node scripts/generate.i18n.ts",
    "__script__based__commands__finish__": "✅ The above section contains commands based on node runner."
  },

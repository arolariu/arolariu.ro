{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: Debug Full Stack",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/sites/arolariu.ro",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "env": {
        "NODE_OPTIONS": "--inspect",
        "NEXT_TURBOPACK_TRACING": "1",
        "EXP_PROXY_URL": "http://localhost:5002"
      },
      "sourceMaps": true,
      "timeout": 30000
    },
    {
      "name": "Next.js: Debug Client-Side",
      "type": "msedge",
      "request": "launch",
      "url": "https://localhost:3000",
      "webRoot": "${workspaceFolder}/sites/arolariu.ro",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${webRoot}/*",
        "webpack:///./*": "${webRoot}/*",
        "webpack:///./~/*": "${webRoot}/node_modules/*"
      }
    },
    {
      "name": "Next.js: Debug Server-Side",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev --workspace @arolariu/website",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithEdge"
      }
    },
    {
      "name": "Launch DocFX site",
      "type": "node-terminal",
      "request": "launch",
      "command": "docfx build sites/docs.arolariu.ro/docfx.json --serve",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": ".NET API: Debug",
      "type": "dotnet",
      "request": "launch",
      "preLaunchTask": "Build: API for Debug",
      "projectPath": "${workspaceFolder}/sites/api.arolariu.ro/src/Core/arolariu.Backend.Core.csproj",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5000",
        "INFRA": "local",
        "EXP_PROXY_URL": "http://localhost:5002"
      }
    },
    {
      "name": "Python: exp FastAPI Debug",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--host", "127.0.0.1", "--port", "5002"],
      "cwd": "${workspaceFolder}/sites/exp.arolariu.ro",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/sites/exp.arolariu.ro",
        "INFRA": "local"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Website + API + exp",
      "configurations": [
        "Next.js: Debug Full Stack",
        ".NET API: Debug",
        "Python: exp FastAPI Debug"
      ],
      "stopAll": true
    }
  ]
}

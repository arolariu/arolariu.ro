    },
    {
      "name": "Caching",
      "item": [
        {
          "name": "10 - Capture ETag",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rest/json",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rest",
                "json"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('ETag header exists and is captured', function () {",
                  "    const etag = pm.response.headers.get('ETag');",
                  "    pm.expect(etag).to.exist;",
                  "    pm.collectionVariables.set('etagValue', etag);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "11 - Validate If-None-Match (304)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "If-None-Match",
                "value": "{{etagValue}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rest/json",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rest",
                "json"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('If-None-Match behavior is valid (304 or refreshed 200)', function () {",
                  "    const previousEtag = pm.collectionVariables.get('etagValue');",
                  "    pm.expect(previousEtag, 'etagValue should be captured before this request').to.exist;",
                  "    pm.expect([200, 304]).to.include(pm.response.code);",
                  "    if (pm.response.code === 304) {",
                  "        return;",
                  "    }",
                  "    const currentEtag = pm.response.headers.get('ETag');",
                  "    pm.expect(currentEtag).to.exist;",
                  "    pm.expect(currentEtag).to.not.equal(previousEtag);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }

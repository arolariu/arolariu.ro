    {
      "name": "CV JSON API",
      "item": [
        {
          "name": "05 - GET /rest/json (full)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rest/json",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rest",
                "json"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Full response has resume and meta', function () {",
                  "    const payload = pm.response.json();",
                  "    pm.expect(payload).to.have.property('resume');",
                  "    pm.expect(payload).to.have.property('meta');",
                  "    pm.expect(payload.meta.format).to.equal('cv.bundle');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "06 - GET /rest/json?format=minimal",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rest/json?format=minimal",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rest",
                "json"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "minimal"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Minimal response includes basics/work', function () {",
                  "    const payload = pm.response.json();",
                  "    pm.expect(payload).to.have.property('basics');",
                  "    pm.expect(payload).to.have.property('work');",
                  "    pm.expect(payload.meta.format).to.equal('cv.minimal');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "07 - GET /rest/json?format=resume",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rest/json?format=resume",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rest",
                "json"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "resume"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Resume format returns resume schema content', function () {",
                  "    const payload = pm.response.json();",
                  "    pm.expect(payload).to.have.property('basics');",
                  "    pm.expect(payload).to.have.property('work');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "08 - GET /rest/json?section={{sectionName}}",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rest/json?section={{sectionName}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rest",
                "json"
              ],
              "query": [
                {
                  "key": "section",
                  "value": "{{sectionName}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Section response returns selected section data', function () {",
                  "    const payload = pm.response.json();",
                  "    const sectionName = pm.environment.get('sectionName') || pm.collectionVariables.get('sectionName');",
                  "    pm.expect(payload.section).to.equal(sectionName);",
                  "    pm.expect(payload).to.have.property('data');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "09 - GET /rest/json?section=unknown (404)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rest/json?section=unknown-section",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rest",
                "json"
              ],
              "query": [
                {
                  "key": "section",
                  "value": "unknown-section"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Unknown section returns 404 contract', function () {",
                  "    pm.expect(pm.response.code).to.equal(404);",
                  "    const payload = pm.response.json();",
                  "    pm.expect(payload).to.have.property('error');",
                  "    pm.expect(payload).to.have.property('availableSections');",
                  "    pm.expect(payload.availableSections).to.be.an('array').that.is.not.empty;",
                  "});"
                ]
              }
            }
          ]

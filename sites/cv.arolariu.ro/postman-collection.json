{
  "$schema": "https://schema.postman.com/collection/json/v2.1.0/draft-04/collection.json",
  "info": {
    "name": "cv.arolariu.ro",
    "description": "Live E2E checks for cv.arolariu.ro routes and /rest/json API contract.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "cv-arolariu-ro-live-tests",
    "version": "1.0.0"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function readConfig(key, fallback) {",
          "    const collectionValue = pm.collectionVariables.get(key);",
          "    const environmentValue = pm.environment.get(key);",
          "    const resolvedValue = environmentValue ?? collectionValue;",
          "    return resolvedValue === undefined || resolvedValue === null || String(resolvedValue).trim() === '' ? fallback : String(resolvedValue);",
          "}",
          "",
          "const baseUrl = readConfig('baseUrl', '');",
          "if (!baseUrl) {",
          "    console.warn('Warning: baseUrl is not set.');",
          "}",
          "pm.variables.set('requestTimestamp', new Date().toISOString());",
          "console.log(`[${pm.info.requestName}] Starting request at ${pm.variables.get('requestTimestamp')}`);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function readConfig(key, fallback) {",
          "    const collectionValue = pm.collectionVariables.get(key);",
          "    const environmentValue = pm.environment.get(key);",
          "    const resolvedValue = environmentValue ?? collectionValue;",
          "    return resolvedValue === undefined || resolvedValue === null || String(resolvedValue).trim() === '' ? fallback : String(resolvedValue);",
          "}",
          "",
          "function readPositiveNumber(key, fallback) {",
          "    const rawValue = readConfig(key, String(fallback));",
          "    const parsedValue = Number(rawValue);",
          "    return Number.isFinite(parsedValue) && parsedValue > 0 ? parsedValue : fallback;",
          "}",
          "",
          "const requestName = pm.info.requestName || '';",
          "const expects404 = requestName.includes('(404)');",
          "const expectedStatusCodes = expects404 ? [404] : [200, 301, 302, 303, 307, 308, 304];",
          "",
          "pm.test('Response status is expected for this route', function () {",
          "    pm.expect(expectedStatusCodes).to.include(pm.response.code);",
          "});",
          "",
          "pm.test('Response time is below configured failure threshold', function () {",
          "    const warningThreshold = readPositiveNumber('warningLatencyMs', 1500);",
          "    const failureThreshold = readPositiveNumber('failureLatencyMs', 3000);",
          "    pm.expect(pm.response.responseTime).to.be.below(failureThreshold,",
          "        `Response time ${pm.response.responseTime}ms exceeds ${failureThreshold}ms`);",
          "    if (pm.response.responseTime > warningThreshold) {",
          "        console.warn(`Warning latency threshold exceeded: ${pm.response.responseTime}ms > ${warningThreshold}ms`);",
          "    }",
          "});",
          "",
          "pm.test('Content-Type is present for non-304 responses', function () {",
          "    if (pm.response.code === 304) {",
          "        this.skip();",
          "        return;",
          "    }",
          "    const contentType = pm.response.headers.get('Content-Type');",
          "    pm.expect(contentType).to.exist;",
          "});"
        ]
      }
    }
  ],
  "item": [

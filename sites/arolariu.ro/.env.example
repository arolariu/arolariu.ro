# In order to get a build up and running, you need to configure some environment variables.
# The preferred runtime contract is now exp-driven: the website resolves API URL,
# API auth secret, feature flags, and optional Resend settings from the exp service
# on the server. Only a narrow set of build/runtime env vars should remain primary.
#
# The legacy fallback values shown below are optional compatibility inputs. They are
# only used when exp is unavailable or in isolated test scenarios and should not be
# treated as the normal production runtime path.
#
# NEVER submit real secrets in any versioning system. If you do, rotate them ASAP.

# ----------------------------------------------------------- #

# Generated environment configuration
# Site Environment: development
# CI/CD: false
# Commit SHA: N/A
# Generated at: 2025-06-08T09:02:12.412Z
# !!!! DO NOT EDIT HERE !!!

# Site Configuration Start
SITE_ENV= # is either "DEVELOPMENT" or "PRODUCTION"
SITE_NAME= # the name of the site, e.g. "dev.arolariu.ro" or "arolariu.ro"
SITE_URL= # the URL of the site, e.g. "http://localhost:3000" or "https://arolariu.ro"
# Site Configuration End

# Accepted Authentication Configuration Start
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY= # The Clerk publishable key for auth.
CLERK_SECRET_KEY= # The Clerk secret key for auth.
# Accepted Authentication Configuration End

# Accepted Azure Runtime Identity Start
AZURE_CLIENT_ID= # Set on Azure App Service to enable managed identity + https://exp.arolariu.ro routing.
AZURE_TENANT_ID= # Optional Azure deployment identifier.
AZURE_SUBSCRIPTION_ID= # Optional Azure deployment identifier.
# Accepted Azure Runtime Identity End

# Metadata Configuration Start
TIMESTAMP= # The timestamp of the build, e.g. "2025-06-08T09:02:12.412Z"
COMMIT_SHA= # The commit SHA of the build, e.g. "c4d9d9ade7e30908b49d7c6d64b1328e4b31eb4b"
USE_CDN= # Set to "true" to use CDN for static assets prefix, otherwise "false".
# Metadata Configuration End

# Legacy Optional Fallbacks Start
API_ENV= # Optional compatibility metadata for older setup tooling.
API_NAME= # Optional compatibility metadata for older setup tooling.
API_URL= # Optional fallback for exp-backed API URL resolution.
API_JWT= # Optional fallback for exp-backed API auth secret resolution.
RESEND_API_KEY= # Optional fallback for exp-backed Resend key resolution.
CONFIG_STORE= # Optional legacy Azure App Configuration value for non-exp tooling only.
# Legacy Optional Fallbacks End
